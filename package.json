{
  "name": "lithos",
  "version": "1.0.0",
  "description": "AI-powered rock and mineral identification app with social trading features",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
